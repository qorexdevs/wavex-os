# Build artifacts
.tmp/
node_modules/
*.log
dist/
build/
out/
.next/
.turbo/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Environment / secrets (NEVER commit these)
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# Per-deployment WaveX OS config (CONTAINS YOUR COMPANY ID — never commit)
wavex-os.config.json
!examples/wavex-os.config.example.json
!examples/kpi-registry.example.json

# Backup files (from migration scripts)
*.bak
*.backup
*.old

# Lock files (keep selectively)
# Allow pnpm-lock.yaml, package-lock.json — block npm-shrinkwrap.json + yarn.lock if undesired
yarn.lock
npm-shrinkwrap.json

# Claude Code session caches (sensitive prompts/contexts)
.claude/projects/
.claude/sessions/
.claude/cache/

# Local dev databases
*.sqlite
*.sqlite3
*.db

# Coverage / test artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
*.tsbuildinfo

# Demo recordings — large MP4/WebM files generated by scripts/demo-walk.mjs
scripts/demo-recordings/

# TypeScript incremental build cache
*.tsbuildinfo

# Session-specific Paperclip data (NEVER commit user company data)
~/.paperclip/
vendor/op-omega/*/dist/

# Playwright artifacts (don't commit reports/traces — only the test specs)
playwright-report/
test-results/


# Supabase CLI temp state (project ref, version markers)
supabase/.temp/

# Operator-local QA spec fixtures (not shipped in customer installs)
e2e/_qa-*.spec.ts
