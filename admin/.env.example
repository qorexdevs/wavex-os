# WaveX OS Meta Mission Control — environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Supabase project URL. Format: https://<YOUR_REF>.supabase.co
SUPABASE_URL=

# Service-role key for the same project. Grants full read of wavex_os.* schema.
# Treat as a root credential — server-side ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used to verify admin tokens. Get this from Supabase project settings → API → JWT secret.
SUPABASE_JWT_SECRET=

# Comma-separated email addresses allowed to view the dashboard.
# A user is admitted iff their verified Supabase JWT email is in this list
# AND the JWT has app_metadata.admin === true (set via the Supabase admin API or SQL).
ADMIN_USER_EMAILS=

# Optional. Port to bind Fastify to. Defaults to 8080.
PORT=8080

# Optional. Host to bind to. Defaults to 0.0.0.0 for container deploys.
HOST=0.0.0.0

# Optional. Log level: trace | debug | info | warn | error. Defaults to info.
LOG_LEVEL=info
