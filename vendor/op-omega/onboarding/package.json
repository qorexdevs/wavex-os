{
  "name": "@op-omega/plugin-onboarding",
  "version": "0.1.0",
  "description": "Operator Ω 4-phase onboarding manifest-generation pipeline (OPΩ-ONB-002). Produces pillar_responses.json → connector_manifest.yaml → swarm_manifest.yaml → workflow_manifest.yaml → company.manifest.yaml. Consumes tier-router for inference and flywheel-kernel for Monte Carlo.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "prebuild": "node ../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*",
    "@op-omega/plugin-tier-router": "workspace:*",
    "@op-omega/plugin-flywheel-kernel": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
