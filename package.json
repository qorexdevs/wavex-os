{
  "name": "wavex-os",
  "version": "0.1.0",
  "description": "Open-source operating system for running an AI agent company. Clone, run, configure your fleet in 45 minutes.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm dev:full",
    "dev:full": "pnpm --parallel --filter \"./packages/onboarding-ui\" --filter \"./packages/mock-core\" dev",
    "dev:ui": "pnpm --filter \"./packages/onboarding-ui\" dev",
    "dev:core": "pnpm --filter \"./packages/mock-core\" dev",
    "build": "pnpm -r --filter \"!./packages/core\" build",
    "ingest:templates": "node scripts/ingest-agency-agents.mjs",
    "lint": "echo 'TODO: eslint'",
    "test": "pnpm -r --filter \"@wavex-os/db\" test",
    "db:up": "pnpm --filter @wavex-os/db db:up",
    "db:migrate": "pnpm --filter @wavex-os/db db:migrate",
    "db:reset": "pnpm --filter @wavex-os/db db:reset"
  },
  "packageManager": "pnpm@8.15.0"
}
