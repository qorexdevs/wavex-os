{
  "name": "wavex-os",
  "version": "0.1.0",
  "description": "Open-source operating system for running an AI agent company. Clone, run, configure your fleet in 45 minutes.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm install --prefer-offline && pnpm dev:everything",
    "dev:everything": "pnpm dev:paperclip:install && pnpm dev:wavex-plugin:build && pnpm --parallel --filter \"./packages/onboarding-ui\" --filter \"./packages/mock-core\" --filter \"paperclip\" dev",
    "dev:no-paperclip": "pnpm --parallel --filter \"./packages/onboarding-ui\" --filter \"./packages/mock-core\" dev",
    "dev:ui": "pnpm --filter \"./packages/onboarding-ui\" dev",
    "dev:core": "pnpm --filter \"./packages/mock-core\" dev",
    "dev:paperclip": "pnpm dev:paperclip:install && pnpm dev:wavex-plugin:build && pnpm --filter paperclip dev",
    "dev:paperclip:install": "cd packages/core && pnpm install --prefer-offline",
    "dev:wavex-plugin:build": "pnpm --filter @wavex-os/paperclip-plugin-wavex build || echo 'wavex plugin build skipped (typecheck-only mode)'",
    "dev:full": "pnpm dev:everything",
    "build": "pnpm -r --filter \"!./packages/core\" build",
    "ingest:templates": "node scripts/ingest-agency-agents.mjs",
    "lint": "echo 'TODO: eslint'",
    "test": "pnpm -r --filter \"@wavex-os/db\" test",
    "db:up": "pnpm --filter @wavex-os/db db:up",
    "db:migrate": "pnpm --filter @wavex-os/db db:migrate",
    "db:reset": "pnpm --filter @wavex-os/db db:reset",
    "tuning:map": "node_modules/.pnpm/node_modules/.bin/tsx vendor/wavex-os/onboarding/src/tuning/print-map.ts",
    "tuning:chart": "node_modules/.pnpm/node_modules/.bin/tsx vendor/wavex-os/onboarding/src/tuning/print-chart.ts",
    "baseline:capture": "node_modules/.pnpm/node_modules/.bin/tsx vendor/wavex-os/onboarding/test/baseline/capture.ts",
    "diffeq:suite": "pnpm --filter @wavex-os/plugin-onboarding test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "wavex:login": "node packages/cloud-client/bin/wavex-os.mjs login",
    "wavex:os": "node packages/cloud-client/bin/wavex-os.mjs",
    "wavex:link": "cd packages/cloud-client && pnpm link --global && echo 'wavex-os linked globally — run: wavex-os login'",
    "wavex:cloud-client:smoke": "node_modules/.pnpm/node_modules/.bin/tsx packages/cloud-client/scripts/smoke-offline.mjs",
    "wavex:start": "node scripts/wavex-bootstrap.mjs"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.2"
  }
}
