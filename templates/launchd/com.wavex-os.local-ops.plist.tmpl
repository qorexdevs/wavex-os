<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.wavex-os.local-ops</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>node</string>
    <string>${WAVEX_OS_ROOT}/scripts/wavex-local-ops-cycle.mjs</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>WAVEX_OS_REPO_ROOT</key>
    <string>${WAVEX_OS_ROOT}</string>
    <key>WAVEX_OS_STATE_DIR</key>
    <string>${STATE_DIR}</string>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>${STATE_DIR}/wavex-local-ops.log</string>
  <key>StandardErrorPath</key>
  <string>${STATE_DIR}/wavex-local-ops.log</string>
</dict>
</plist>
